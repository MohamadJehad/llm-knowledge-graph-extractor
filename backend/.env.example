# Copy this file to `.env` and fill in the keys for whichever providers you want enabled.
# Leave a key blank/missing to disable that provider — the UI will only show configured ones.

# --- Anthropic (Claude) ---
# Get from: https://console.anthropic.com (Settings → API Keys)
ANTHROPIC_API_KEY=

# --- OpenAI (GPT) ---
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Google (Gemini) ---
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSyCtnqirJkz12KlUj403ge2UpkQlm-JXByM 

# --- Ollama (local, free) ---
# Install Ollama from https://ollama.com, then run:
#   ollama pull llama3.1
# (Or any model — qwen2.5, mistral, gemma2, etc.)
# The backend auto-detects whether the daemon is running on OLLAMA_HOST.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Server ---
PORT=3001
