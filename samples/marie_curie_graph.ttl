@prefix kg: <http://kg-extractor.local/entity/> .
@prefix rel: <http://kg-extractor.local/relation/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

kg:marie_curie a kg:Person ;
    rdfs:label "Marie Curie" ;
    rdfs:comment "Polish-born physicist and chemist, first woman to win a Nobel Prize." ;
    kg:source_sentence "Marie Curie was a Polish-born physicist and chemist who became the first woman to win a Nobel Prize." ;
    kg:source_sentence "Born Maria Skłodowska in Warsaw in 1867, she moved to Paris in 1891 to study at the Sorbonne." .

kg:warsaw a kg:Location ;
    rdfs:label "Warsaw" ;
    rdfs:comment "Polish city where Marie Curie was born in 1867." ;
    kg:source_sentence "Born Maria Skłodowska in Warsaw in 1867, she moved to Paris in 1891 to study at the Sorbonne." .

kg:paris a kg:Location ;
    rdfs:label "Paris" ;
    rdfs:comment "French city where Marie Curie studied and conducted her research." ;
    kg:source_sentence "Born Maria Skłodowska in Warsaw in 1867, she moved to Paris in 1891 to study at the Sorbonne." .

kg:sorbonne a kg:Organization ;
    rdfs:label "Sorbonne" ;
    rdfs:comment "Parisian university where Marie Curie pursued her studies." ;
    kg:source_sentence "Born Maria Skłodowska in Warsaw in 1867, she moved to Paris in 1891 to study at the Sorbonne." .

kg:pierre_curie a kg:Person ;
    rdfs:label "Pierre Curie" ;
    rdfs:comment "French physicist, husband and research partner of Marie Curie." ;
    kg:source_sentence "She married Pierre Curie in 1895, and together they discovered the elements polonium and radium." .

kg:polonium a kg:Concept ;
    rdfs:label "polonium" ;
    rdfs:comment "Chemical element discovered by Marie and Pierre Curie." ;
    kg:source_sentence "She married Pierre Curie in 1895, and together they discovered the elements polonium and radium." .

kg:radium a kg:Concept ;
    rdfs:label "radium" ;
    rdfs:comment "Chemical element discovered by Marie and Pierre Curie; subject of her second Nobel Prize." ;
    kg:source_sentence "She married Pierre Curie in 1895, and together they discovered the elements polonium and radium." ;
    kg:source_sentence "Marie Curie won the Nobel Prize in Physics in 1903, shared with Pierre and Henri Becquerel, and a second Nobel Prize in Chemistry in 1911 for her work on radium." .

kg:henri_becquerel a kg:Person ;
    rdfs:label "Henri Becquerel" ;
    rdfs:comment "French physicist who shared the 1903 Nobel Prize with the Curies." ;
    kg:source_sentence "Marie Curie won the Nobel Prize in Physics in 1903, shared with Pierre and Henri Becquerel, and a second Nobel Prize in Chemistry in 1911 for her work on radium." .

kg:nobel_prize_physics_1903 a kg:Event ;
    rdfs:label "Nobel Prize in Physics (1903)" ;
    rdfs:comment "Awarded to Marie Curie, Pierre Curie, and Henri Becquerel." ;
    kg:source_sentence "Marie Curie won the Nobel Prize in Physics in 1903, shared with Pierre and Henri Becquerel, and a second Nobel Prize in Chemistry in 1911 for her work on radium." .

kg:nobel_prize_chemistry_1911 a kg:Event ;
    rdfs:label "Nobel Prize in Chemistry (1911)" ;
    rdfs:comment "Awarded to Marie Curie for her work on radium." ;
    kg:source_sentence "Marie Curie won the Nobel Prize in Physics in 1903, shared with Pierre and Henri Becquerel, and a second Nobel Prize in Chemistry in 1911 for her work on radium." .

kg:curie_institute a kg:Organization ;
    rdfs:label "Curie Institute" ;
    rdfs:comment "Medical research institution founded by Marie Curie in Paris." ;
    kg:source_sentence "She founded the Curie Institute in Paris, which remains a major center for medical research." .

